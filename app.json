{
  "expo": {
    "scheme": "linkpond",
    "name": "linkpond",
    "slug": "linkpond",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.prasish07.linkpond"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-sqlite",
      "expo-image",
      "expo-share-intent"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b44767e-01f3-4f2f-b922-515ee0097ae1"
      }
    }
  }
}
